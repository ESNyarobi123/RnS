# Laravel Application URL
LARAVEL_URL=http://localhost:8000
HOST=127.0.0.1
PORT=3000

# WhatsApp Bot Configuration
# This must match the secret configured in Admin -> Bot Control on the web app
BOT_SECRET_KEY=your-secret-key-here-your-secret-key-here-your-secret-key-here
# Optional: force one browser profile instead of automatic fallback rotation
# BOT_BROWSER_PROFILE=macos

# Local Session Storage
BOT_SESSION_FILE=storage/sessions.json

# API Configuration
API_TIMEOUT=30000
API_RETRIES=3

# Logging
LOG_LEVEL=info
LOG_FILE=logs/bot.log
